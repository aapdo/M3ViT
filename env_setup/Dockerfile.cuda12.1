# NGC PyTorch Docker image with custom requirements
# Build with: 
# docker build -t m3vit_leg:260323 -f env_setup/Dockerfile.cuda12.1 .
# Start with:
# docker run --gpus all --shm-size="120g" -d --name m3vit_ssh \
#     -p 9795:22 \
#     -v /home/tako8/share/user-share/jy/m3vit:/home/jy/m3vit \
#     -v /home/tako8/share/user-share/jy/multi_task_datasets:/home/jy/multi_task_datasets \
#     m3vit_leg:260323
#
# SSH into container:
#     ssh -p 2222 jy@localhost

FROM nvcr.io/nvidia/pytorch:24.01-py3

RUN apt-get update

# Copy requirements
COPY env_setup/requirements.txt /tmp/requirements.txt

# Copy entrypoint script
# COPY env_setup/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
# RUN chmod 777 /usr/local/bin/docker-entrypoint.sh

# Install FastMoE
RUN git clone https://github.com/laekov/fastmoe.git /tmp/fastmoe \
    && cd /tmp/fastmoe \
    && python setup.py install \
    && cd / \
    && rm -rf /tmp/fastmoe

# ---------------------------------------------------
# 1) Remove ALL system-level OpenCV to avoid conflicts
# ---------------------------------------------------
RUN apt-get remove -y python3-opencv || true \
    && apt-get purge -y python3-opencv || true \
    && rm -rf /usr/local/lib/python3.10/dist-packages/cv2* \
    && rm -rf /usr/lib/python3/dist-packages/cv2* \
    && rm -rf /usr/local/lib/python3.10/site-packages/cv2* \
    && rm -rf /usr/lib/python3.10/site-packages/cv2*


# Install system packages needed for cv2 + GUI deps + SSH
RUN apt-get update && apt-get install -y \
    vim sudo tmux \
    openssh-server \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxrender1 \
    libxext6 \
    && rm -rf /var/lib/apt/lists/*

# SSH server configuration
RUN mkdir -p /var/run/sshd \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config \
    && sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/#Port 22/Port 22/' /etc/ssh/sshd_config

EXPOSE 22

# Create user and group 'jy' with fixed UID/GID 1003
RUN groupadd -g 1003 jy \
    && useradd -m -s /bin/bash -u 1003 -g 1003 jy \
    && echo "jy:1234" | chpasswd \
    && echo "jy ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
WORKDIR /home/jy

# --------------------------------------------------------
# 2) Install Python dependencies (requirements.txt includes
#    opencv-python==4.6.0.66 — pip version ONLY)
# --------------------------------------------------------
# This guarantees cv2 will come ONLY from pip.
RUN pip install --no-cache-dir -r /tmp/requirements.txt \
    && rm /tmp/requirements.txt

RUN python -m pip install -U typing_extensions

# Install mmcv 1.7.1 (no-build-isolation required for NGC base image)
RUN python -m pip install --no-build-isolation mmcv==1.7.1

# Fix protobuf/onnx compatibility (NGC base ships old onnx with stale _pb2 codegen)
RUN pip install --no-cache-dir protobuf==4.25.8 onnx==1.20.1

# Install Node.js 22 + Claude Code CLI
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g @anthropic-ai/claude-code \
    && rm -rf /var/lib/apt/lists/*

RUN echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc

USER jy

# Configure wandb MCP for Claude Code
RUN mkdir -p /home/jy/.claude \
    && echo '{"mcpServers":{"wandb":{"type":"http","url":"https://mcp.withwandb.com/mcp","headers":{"Authorization":"Bearer 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"}}}}' > /home/jy/.claude.json

# Start sshd in background, then keep container alive
CMD sudo /usr/sbin/sshd && sleep infinity